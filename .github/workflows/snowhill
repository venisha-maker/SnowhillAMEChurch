<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snowhill A.M.E Church</title>

    <style>
        /* ---------- GLOBAL STYLES ---------- */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f7f7f7;
            color: #333;
            line-height: 1.6;
        }

        header {
            background: #2c3e50;
            color: #fff;
            padding: 20px 40px;
            text-align: center;
        }

        nav {
            background: #4a8deb;
            display: flex;
            justify-content: center;
            gap: 30px;
            padding: 10px 0;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .hero {
            background: url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee') center/cover no-repeat;
            height: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-shadow: 0 2px 4px rgba(0,0,0,0.6);
            font-size: 2rem;
            font-weight: bold;
        }

        .container {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .section-title {
            font-size: 1.8rem;
            margin-bottom: 10px;
            color: #2c3e50;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        footer {
            background: #2c3e50;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 40px;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <header>
        <h1>Snowhill A.M.E Church</h1>
        <p>“A Place of Faith, Family, Fellowship, and Love”</p>
    </header>

    <!-- NAVIGATION -->
    <nav>
        <a href="#">About</a>
        <a href="#">Events</a>
        <a href="#">Contact</a>
    </nav>

    <!-- HERO SECTION -->
    <div class="hero">
        Welcome Home
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">

        <div class="card">
            <h2 class="section-title">Sunday Service</h2>
            <p>Join us every Sunday at 10:00 AM for worship and fellowship.</p>
        </div>

        <div class="card">
            <h2 class="section-title">Upcoming Events</h2>
            <ul>
                <li>Christmas Choir Rehearsal – Dec 22</li>
                <li>Youth Night – Jan 12</li>
            </ul>
        </div>

        <div class="card">
            <h2 class="section-title">Our Mission</h2>
            <p>
                We are committed to spreading the love of Christ, serving our community, 
                and helping individuals grow spiritually through worship, discipleship, 
                and outreach.
            </p>
        </div>

    </div>

    <!-- FOOTER -->
    <footer>
        © 2025 Snowhill A.M.E Church — All Rights Reserved
    </footer>

</body>
</html>
